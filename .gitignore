### VS Code ###
.vscode/

# Ignore local env files containing secrets
.env
.env.postgres
.env.amadeus

# Claude Code user-specific local settings (not for shared repos)
.claude/settings.local.json

# Runtime log and error files
*.log
*.err
logs/

# Debug / manual test data dumps (API snapshots from development)
# These names are not used by any tracked test fixtures, so bare-name patterns are safe
health.json
options.json
latest_options.json
request.json
response.json

# Python bytecode
__pycache__/
*.pyc
*.pyo

# node_modules (covers nested script directories like scripts/db-check/)
node_modules/

# Database migration backup files
*.sql.bak

# Claude Code agent instructions (not for public repo)
CLAUDE.md

# Orphan root lockfile (no root package.json)
/package-lock.json

# Ad-hoc / manual dev test scripts
scripts/pwsearch.ps1
scripts/pwsearch2.ps1
scripts/test_search.js
scripts/test_search_get.js
scripts/test_search_get2.js
scripts/run_tests_iterative.ps1
